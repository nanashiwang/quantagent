# JWT配置（必填）
JWT_SECRET_KEY=change-this-to-a-long-random-secret

# LLM配置
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Tushare配置
TUSHARE_TOKEN=your-tushare-token-here
TUSHARE_API_URL=http://121.40.135.59:8010/
MARKET_DATA_SYMBOLS=000001.SZ,600519.SH,159915.SZ
MARKET_DATA_TYPES=daily,daily_basic,moneyflow
MARKET_DATA_FETCH_INTERVAL=3600
MARKET_DATA_HISTORY_DAYS=30
MARKET_DATA_START_DATE=
MARKET_DATA_END_DATE=
MARKET_DATA_AUTO_SYNC=false

# MongoDB配置（可选，默认本地）
# MONGODB_URI=mongodb://localhost:27017
# MONGODB_DB_NAME=quant_trading

# SQLite与日志路径（可选）
# SQLITE_PATH=data/sqlite/trading.db
# LOG_LEVEL=INFO
# LOG_FILE=logs/app.log

# 初始化管理员（可选，仅首次启动时生效）
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_PASSWORD=change-this-admin-password
