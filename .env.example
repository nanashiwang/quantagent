# =========================
# 基础安全配置
# =========================
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_REMEMBER_ME_EXPIRE_DAYS=30

# 可选：首次启动时初始化管理员
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_PASSWORD=change-this-admin-password


# =========================
# Run-centric 数据库配置
# =========================
# 开发环境默认使用 SQLite
DATABASE_URL=sqlite+pysqlite:///./data/sqlite/run_centric.db

# 生产环境改为 PostgreSQL，例如：
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/quant_trading

# 兼容旧命名，可与 DATABASE_URL 二选一
# POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/quant_trading

# 建议生产环境保持 false，统一通过 Alembic 管理结构
AUTO_INIT_SCHEMA=false


# =========================
# 旧系统兼容配置
# =========================
SQLITE_PATH=data/sqlite/trading.db
LOG_LEVEL=INFO
LOG_FILE=logs/app.log


# =========================
# MongoDB 配置
# =========================
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=quant_trading


# =========================
# Celery / Redis 配置
# =========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# =========================
# LLM 配置
# =========================
LLM_PROVIDER=stub
LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4
PROMPT_VERSION=prompt-v1
AGENT_VERSION=agent-v1
FEATURE_SET_VERSION=feature-set-v1
MODEL_VERSION=model-v1


# =========================
# Tushare / 行情配置
# =========================
TUSHARE_TOKEN=your-tushare-token-here
TUSHARE_API_URL=http://121.40.135.59:8010/
DEFAULT_WATCHLIST=000001.SZ,600519.SH,300750.SZ

# 旧系统行情配置
MARKET_DATA_SYMBOLS=000001.SZ,600519.SH,159915.SZ
MARKET_DATA_TYPES=daily,daily_basic,moneyflow,index_daily
MARKET_DATA_FETCH_INTERVAL=3600
MARKET_DATA_HISTORY_DAYS=30
MARKET_DATA_START_DATE=
MARKET_DATA_END_DATE=
MARKET_DATA_AUTO_SYNC=false


# =========================
# 调度 / 外部源配置
# =========================
# RSSHUB_BASE_URL=http://127.0.0.1:1200
DISABLE_NEWS_SCHEDULER=0
DISABLE_MARKET_DATA_SCHEDULER=0


# =========================
# 研究平台配置
# =========================
MLFLOW_TRACKING_URI=file:./mlruns
VECTORSTORE_URI=memory://vectorstore
HOT_KNOWLEDGE_TESTS_THRESHOLD=5
HOT_KNOWLEDGE_PASS_RATE_THRESHOLD=0.65
